{
  "productName": "Photrez",
  "version": "0.1.0",
  "identifier": "com.photrez.app",
  "build": {
    "beforeDevCommand": {
    "script": "bun scripts/dev/kill-port.cjs && bun run dev",
    "wait": false
  },
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Photrez",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "dragDropEnabled": false,
        "visible": false
      },
      {
        "label": "splashscreen",
        "url": "/splash.html?v=2",
        "width": 400,
        "height": 340,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "shadow": false,
        "center": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: https://asset.localhost; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'; connect-src 'self' ipc: https://ipc.localhost http://localhost:1420 ws: https://fonts.googleapis.com https://fonts.gstatic.com; worker-src 'self' blob:; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Rahman Qolbi",
    "copyright": "Copyright © 2026 Rahman Qolbi",
    "licenseFile": "../../../LICENSE",
    "resources": {
      "../../../target/release/WebView2Loader.dll": "WebView2Loader.dll"
    },
    "icon": [
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": null
      }
    }
  }
}
