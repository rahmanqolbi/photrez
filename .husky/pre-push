#!/bin/sh
echo "============================================="
echo "   Running Pre-Push Verification Pipeline   "
echo "============================================="

# 1. Full build (catches vite / TS / bundler errors)
echo ""
echo "[1/3] Running Build..."
bun run build || {
  echo ""
  echo "ERROR: Build failed!"
  exit 1
}

# 2. Component tests (jsdom) — mirrors the CI component-tests job
echo ""
echo "[2/3] Running Component Tests..."
bun run --filter photrez-desktop test:component || {
  echo ""
  echo "ERROR: Component tests failed!"
  exit 1
}

# 3. Lockfile guard — ensure bun.lock is in sync with package.json so the
#    CI `bun install --frozen-lockfile` step does not fail after a dependency
#    change. If this fails, run `bun install` and re-stage bun.lock.
echo ""
echo "[3/3] Verifying bun.lock is in sync..."
bun install --frozen-lockfile || {
  echo ""
  echo "ERROR: bun.lock is out of sync with package.json."
  echo "       Run 'bun install' and stage the updated bun.lock before pushing."
  exit 1
}

echo ""
echo "All pre-push checks passed. Proceeding with push."
