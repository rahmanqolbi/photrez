#!/bin/sh
echo "============================================="
echo "   Running Pre-Commit Verification Pipeline  "
echo "============================================="

# 0a. Block internal workflow labels in staged source files
if git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|rs)$' | xargs grep -ln 'ponytail:' 2>/dev/null | grep -q .; then
  echo ""
  echo "ERROR: Internal label pattern detected in staged source files."
  exit 1
fi

# 0b. Block internal workflow labels in commit message
if [ -f ".git/COMMIT_EDITMSG" ] && grep -q 'ponytail:' .git/COMMIT_EDITMSG 2>/dev/null; then
  echo ""
  echo "ERROR: Internal label pattern detected in commit message."
  exit 1
fi

# Background: warm up Rust compilation while frontend builds
cargo check -p photrez-core &>/dev/null &
RUST_WARM=$!

# 1. TypeScript type-check & Vite build
echo ""
echo "[1/3] Running TypeScript Type Check & Vite Build..."
bun run --filter photrez-desktop build || {
  echo ""
  echo "ERROR: TypeScript compilation or Vite build failed!"
  exit 1
}

# 2. Frontend unit tests
echo ""
echo "[2/3] Running Frontend Unit Tests..."
bun run --filter photrez-desktop test || {
  echo ""
  echo "ERROR: Frontend unit tests failed!"
  exit 1
}

# 3. Rust compilation check & core unit tests
echo ""
echo "[3/3] Running Rust Compilation Check & Core Tests..."
wait $RUST_WARM 2>/dev/null
cargo check -p photrez-core || {
  echo ""
  echo "ERROR: Rust compilation check failed!"
  exit 1
}

cargo test -p photrez-core || {
  echo ""
  echo "ERROR: Rust core unit tests failed!"
  exit 1
}

echo ""
echo "All checks passed. Proceeding with commit."
