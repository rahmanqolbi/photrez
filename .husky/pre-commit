#!/bin/sh
echo "============================================="
echo "   Running Pre-Commit Verification Pipeline  "
echo "============================================="

# 0a. Block internal workflow labels in staged source files
if git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|rs)$' | xargs grep -ln 'ponytail:' 2>/dev/null | grep -q .; then
  echo ""
  echo "ERROR: Internal label pattern detected in staged source files."
  exit 1
fi

# 0b. Block internal workflow labels in commit message
if [ -f ".git/COMMIT_EDITMSG" ] && grep -q 'ponytail:' .git/COMMIT_EDITMSG 2>/dev/null; then
  echo ""
  echo "ERROR: Internal label pattern detected in commit message."
  exit 1
fi

# 1. TypeScript type-check only (faster than full build)
echo ""
echo "[1/5] Running TypeScript Type Check..."
bun run type-check || {
  echo ""
  echo "ERROR: TypeScript type check failed!"
  exit 1
}

# 2. Frontend unit tests (node-only — fast, ~10s)
echo ""
echo "[2/5] Running Frontend Unit Tests..."
bun run --filter photrez-desktop test:unit || {
  echo ""
  echo "ERROR: Frontend unit tests failed!"
  exit 1
}

# 3. Rust core unit tests
echo ""
echo "[3/5] Running Rust Core Tests..."
cargo test -p photrez-core || {
  echo ""
  echo "ERROR: Rust core tests failed!"
  exit 1
}

# 4. Full build (catches vite / TS / bundler errors the type-check alone misses)
echo ""
echo "[4/5] Running Build..."
bun run build || {
  echo ""
  echo "ERROR: Build failed!"
  exit 1
}

# 5. Component tests (jsdom) — mirrors the CI component-tests job
echo ""
echo "[5/5] Running Component Tests..."
bun run --filter photrez-desktop test:component || {
  echo ""
  echo "ERROR: Component tests failed!"
  exit 1
}

# 6. Lockfile guard — ensure bun.lock is in sync with package.json so the
#    CI `bun install --frozen-lockfile` step does not fail after a dependency
#    change. If this fails, run `bun install` and re-stage bun.lock.
echo ""
echo "[6/6] Verifying bun.lock is in sync..."
bun install --frozen-lockfile || {
  echo ""
  echo "ERROR: bun.lock is out of sync with package.json."
  echo "       Run 'bun install' and stage the updated bun.lock before committing."
  exit 1
}

echo ""
echo "All checks passed. Proceeding with commit."
