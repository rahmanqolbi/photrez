#!/bin/sh
# Commit message grooming — reject AI tooling self-references
# ponytail: grep is enough, no need for a full linter

if grep -qiE '\bAI\s+agent\b|\bagentic\b|\bsubagent\b' "$1"; then
  echo ""
  echo "❌ Commit message contains AI-tooling terminology ('AI agent', 'agentic', 'subagent')."
  echo "   Describe the change, not the tool that made it."
  echo "   Example: 'feat: add layer opacity slider' not 'feat: use AI agent to add slider'"
  echo ""
  exit 1
fi
