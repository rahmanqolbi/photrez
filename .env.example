# Photrez Environment Variables Template
# Copy this file to '.env' in the root directory and fill in your keys.
# DO NOT commit '.env' containing real secrets to the repository.

# Zyloo AI Gateway API Key (Used for developer workflow integration)
# ZYLOO_API_KEY=your-zyloo-api-key-here

# OpenAI API Key (Alternative developer workflow model runner)
# OPENAI_API_KEY=your-openai-api-key-here
