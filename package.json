{
  "name": "photrez-workspace",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter photrez-desktop dev",
    "build": "pnpm --filter photrez-desktop build",
    "test": "pnpm --filter photrez-desktop test",
    "type-check": "pnpm --filter photrez-desktop type-check",
    "lint": "pnpm --filter photrez-desktop lint",
    "test:e2e": "pnpm --filter photrez-desktop test:e2e",
    "test:dialogs": "pnpm --filter photrez-desktop test:dialogs",
    "audit": "pnpm audit --prod && cargo audit",
    "perf:paint-history": "pnpm --filter photrez-desktop perf:paint-history",
    "verify": "pnpm --filter photrez-desktop test --run && pnpm run build && cargo test -p photrez-core && cargo test --workspace",
    "tauri": "tauri",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "husky": "^9.1.7"
  },
  "pnpm": {
    "overrides": {
      "undici": "^7.28.0",
      "esbuild": "^0.28.1"
    }
  }
}
